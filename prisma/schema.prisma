generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Subscription {
  id           String   @id @default(cuid())
  customer     String
  email        String
  status       SubscriptionStatus
  plan         String
  amount       Int      // store in cents
  startDate    DateTime
  renewDate    DateTime
  lastPayment  DateTime
}

enum SubscriptionStatus {
  active
  cancelled
  past_due
  trialing
}